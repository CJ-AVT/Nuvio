# Hoist React into the root node_modules so editors that resolve from the repo root
# still see `react` / `@types/react` (fixes TS2307 when apps/demo-app/node_modules is thin).
public-hoist-pattern[]=*react*
public-hoist-pattern[]=*react-dom*
public-hoist-pattern[]=@types/react*
public-hoist-pattern[]=@types/react-dom*
