    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@nuvio/overlay": "workspace:*",
    "@nuvio/vite-plugin": "workspace:*",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.3",
    "vite": "^6.4.2"
  }
}

