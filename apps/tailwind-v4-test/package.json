{
  "name": "@nuvio/tailwind-v4-test",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "pnpm --filter @nuvio/shared run build && pnpm --filter @nuvio/ast-engine run build && pnpm --filter @nuvio/overlay run build && pnpm --filter @nuvio/vite-plugin run build",
    "dev": "vite",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
