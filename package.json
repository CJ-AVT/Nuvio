{
  "name": "nuvio",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "pnpm -r --filter \"!./packages/next\" --filter \"./packages/**\" run build",
    "typecheck": "pnpm -r --filter \"!./apps/next-dogfood\" run typecheck",
    "test": "pnpm -r run test",
    "dev": "pnpm dev:tailadmin",
    "dev:tailadmin": "pnpm build && pnpm --filter @nuvio/tailadmin-dogfood dev",
    "dogfood": "pnpm build && pnpm typecheck && pnpm test && pnpm --filter @nuvio/demo-app build",
    "test:cli": "pnpm --filter @nuvio/cli test",
    "coverage:dogfood": "node packages/cli/dist/cli-entry.js coverage verify --all --cwd apps/tailadmin-dogfood",
    "brand:dogfood": "node packages/cli/dist/cli-entry.js brand scan --all --cwd apps/tailadmin-dogfood",
    "brand:apply:dogfood": "node packages/cli/dist/cli-entry.js brand apply --all --cwd apps/tailadmin-dogfood",
    "publish:alpha": "pnpm -r publish --filter \"./packages/*\" --access public --tag alpha",
    "publish:stable": "pnpm -r publish --filter \"@nuvio/shared\" --filter \"@nuvio/ast-engine\" --filter \"@nuvio/vite-plugin\" --filter \"@nuvio/overlay\" --filter \"@nuvio/cli\" --access public"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.13.5",
    "typescript": "^5.7.3"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "react": "19",
        "react-dom": "19"
      }
    }
  }
}
