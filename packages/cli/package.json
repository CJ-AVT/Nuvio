{
  "name": "@rte/cli",
  "version": "1.1.0",
  "description": "Rte CLI 1.0 — Vite + Tailwind onboarding and diagnostics (init, doctor, scan, stats).",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ehah/Rte.git",
    "directory": "packages/cli"
  },
  "keywords": [
    "rte",
    "vite",
    "tailwind",
    "tailwindcss",
    "react",
    "cli",
    "devtools",
    "visual-editor"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "templates",
    "package.json",
    "README.md"
  ],
  "type": "module",
  "bin": {
    "rte": "./dist/cli-entry.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup src/cli-entry.ts --format esm --clean --external @babel/parser --external @babel/traverse --external @babel/generator --external @babel/types --external fast-glob --external @rte/vite-plugin --external @rte/shared --external @rte/ast-engine",
    "prepublishOnly": "bun run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@rte/ast-engine": "workspace:*",
    "@rte/shared": "workspace:*",
    "@rte/vite-plugin": "workspace:*",
    "@babel/generator": "^7.26.9",
    "@babel/parser": "^7.26.9",
    "@babel/traverse": "^7.26.9",
    "@babel/types": "^7.26.9",
    "fast-glob": "^3.3.3"
  },
  "devDependencies": {
    "@types/babel__generator": "^7.6.8",
    "@types/babel__traverse": "^7.20.7",
    "@types/node": "^22.13.5",
    "tsup": "^8.4.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.6"
  }
}
