{
  "name": "@rte/ast-engine",
  "version": "1.1.0",
  "description": "Rte AST patch engine: parse TSX/JSX, apply whitelist Tailwind merges and text edits, format with Prettier.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ehah/Rte.git",
    "directory": "packages/ast-engine"
  },
  "keywords": ["rte", "ast", "tsx", "tailwind", "babel"],
  "publishConfig": {
    "access": "public"
  },
  "files": ["dist", "README.md"],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "prepublishOnly": "bun run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@babel/generator": "^7.26.9",
    "@babel/parser": "^7.26.9",
    "@babel/traverse": "^7.26.9",
    "@babel/types": "^7.26.9",
    "@rte/shared": "workspace:*",
    "prettier": "^3.5.1",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@types/babel__traverse": "^7.20.7",
    "@types/node": "^22.13.5",
    "tsup": "^8.4.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.6"
  }
}
