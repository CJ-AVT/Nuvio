{
  "name": "@rte/overlay",
  "version": "1.1.0",
  "description": "Rte overlay 1.0 — dev-only visual editor for React + Vite + Tailwind (Simple Mode, click-to-tag, apply/undo).",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ehah/Rte.git",
    "directory": "packages/overlay"
  },
  "keywords": [
    "rte",
    "vite",
    "overlay",
    "devtools",
    "react"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "sideEffects": [
    "./dist/index.js",
    "./dist/style.css"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./style.css": "./dist/style.css"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "bun run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "react": "^18.3.1 || ^19.0.0",
    "react-dom": "^18.3.1 || ^19.0.0"
  },
  "dependencies": {
    "@rte/shared": "workspace:*",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@rte/ast-engine": "workspace:*",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "jsdom": "^26.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.6"
  }
}
